<%= form_with(model: room_facility, class: "contents text-white flex flex-col gap-5 mt-4" ) do |form| %>
  <% if room_facility.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(room_facility.errors.count, "error") %> prohibited this room_facility from being saved:</h2>

      <ul>
        <% room_facility.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.text_field :facility_id, placeholder: "facility_id", class: ["block shadow-sm rounded-md border bg-gray-700 px-3 py-2 mt-2 w-full", {"border-gray-600 focus:outline-blue-600": room_facility.errors[:facility_id].none?, "border-red-400 focus:outline-red-600": room_facility.errors[:facility_id].any?}] %>
  </div>

  <div>
    <%= form.text_field :room_id, placeholder: "room_id", class: ["block shadow-sm rounded-md border bg-gray-700 px-3 py-2 mt-2 w-full", {"border-gray-600 focus:outline-blue-600": room_facility.errors[:room_id].none?, "border-red-400 focus:outline-red-600": room_facility.errors[:room_id].any?}] %>
  </div>

  <div>
    <%= form.submit nil, class:"font-bold px-4 py-2 bg-blue-600 text-white rounded-md shadow-md hover:bg-blue-500 inline-flex items-center" %>
  </div>
<% end %>