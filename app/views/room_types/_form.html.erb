<%= form_with(model: room_type, local: true, class: "bg-white rounded-lg shadow-md p-6") do |form| %>
  <% if room_type.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(room_type.errors.count, "error") %> prohibited this room type from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% room_type.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <div class="space-y-6">
    <!-- Name Field -->
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name, 
          placeholder: "Enter room type name (e.g., Standard, Deluxe, Suite)", 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors #{'border-red-300 focus:ring-red-500 focus:border-red-500' if room_type.errors[:name].any?}" %>
      <% if room_type.errors[:name].any? %>
        <p class="mt-1 text-sm text-red-600">
          <%= room_type.errors[:name].first %>
        </p>
      <% end %>
    </div>
    <!-- Submit Button -->
    <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
      <%= link_to "Cancel", room_types_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors" %>
      <%= form.submit room_type.persisted? ? "Update Room Type" : "Create Room Type", 
          class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
    </div>
  </div>
<% end %>