<nav class="flex items-center justify-between px-4 py-6">
  <!-- Page info -->
  <div class="text-sm text-gray-500 dark:text-gray-400">
    <%== pagy_info(pagy) %>
  </div>
  <!-- Navigation buttons -->
  <div class="flex items-center gap-2">
    <%= link_to pagy.prev ? url_for(page: pagy.prev) : "#", 
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg border transition-colors #{pagy.prev ? 'border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800' : 'border-gray-200 text-gray-400 cursor-not-allowed dark:border-gray-700 dark:text-gray-600'}", 
            disabled: !pagy.prev,
            "aria-label": "Previous page" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <%= link_to pagy.next ? url_for(page: pagy.next) : "#", 
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg border transition-colors #{pagy.next ? 'border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800' : 'border-gray-200 text-gray-400 cursor-not-allowed dark:border-gray-700 dark:text-gray-600'}", 
            disabled: !pagy.next,
            "aria-label": "Next page" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>
</nav>