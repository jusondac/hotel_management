<% content_for :title, "Rooms" %>
<div class="p-4 bg-gray-50 dark:bg-gray-900 min-h-screen">
  <!-- Header Section -->
  <div class="mb-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 text-sm font-medium md:space-x-2">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-gray-700 hover:text-blue-600 dark:text-gray-300 dark:hover:text-white" do %>
            <svg class="w-5 h-5 mr-2.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
            </svg>
            Home
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 text-gray-400 md:ml-2 dark:text-gray-500" aria-current="page">Rooms</span>
          </div>
        </li>
      </ol>
    </nav>
    <!-- Title and Actions -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Rooms</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Manage your hotel rooms and availability</p>
      </div>
      <div class="mt-4 sm:mt-0 flex gap-3">
        <%= search_form_for @q, html: { class: "flex gap-2" } do |f| %>
          <div class="relative">
            <%= f.search_field :name_cont, class: "pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", placeholder: "Search rooms..." %>
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>
        <% end %>
        <button data-modal-target="room-modal" data-modal-toggle="room-modal" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          <svg class="w-5 h-5 mr-2 -ml-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd"></path>
          </svg>
          Add Room
        </button>
      </div>
    </div>
  </div>
  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="p-3 bg-blue-100 dark:bg-blue-900 rounded-full">
              <svg class="w-6 h-6 text-blue-600 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Total Rooms</dt>
              <dd class="text-3xl font-bold text-gray-900 dark:text-white"><%= @rooms.count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full">
              <svg class="w-6 h-6 text-green-600 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Available</dt>
              <dd class="text-3xl font-bold text-gray-900 dark:text-white"><%= @rooms.select(&:available?).count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <div class="p-3 bg-red-100 dark:bg-red-900 rounded-full">
              <svg class="w-6 h-6 text-red-600 dark:text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">Occupied</dt>
              <dd class="text-3xl font-bold text-gray-900 dark:text-white"><%= @rooms.reject(&:available?).count %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Rooms Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% @rooms.each do |room| %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border-2 <%= room.available? ? 'border-green-200 dark:border-green-700' : 'border-red-200 dark:border-red-700' %> hover:shadow-lg transition-shadow duration-200">
        <div class="p-6">
          <!-- Room Header -->
          <div class="flex justify-between items-start mb-4">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= room.name %></h3>
              <p class="text-sm text-gray-600 dark:text-gray-400"><%= room.room_type.name %></p>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= room.available? ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300' %>">
              <%= room.available? ? 'Available' : 'Occupied' %>
            </span>
          </div>
          <!-- Price -->
          <div class="mb-4">
            <p class="text-2xl font-bold text-gray-900 dark:text-white">$<%= room.price %></p>
            <p class="text-sm text-gray-600 dark:text-gray-400">per night</p>
          </div>
          <!-- Description -->
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2"><%= room.description %></p>
          <!-- Facilities -->
          <% if room.facilities.room_facilities.any? %>
            <div class="mb-4">
              <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Room Facilities:</p>
              <div class="flex flex-wrap gap-1">
                <% room.facilities.room_facilities.limit(3).each do |facility| %>
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                    <%= facility.name %>
                  </span>
                <% end %>
                <% if room.facilities.room_facilities.count > 3 %>
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400">
                    +<%= room.facilities.room_facilities.count - 3 %> more
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
          <!-- Actions -->
          <div class="flex gap-2">
            <button data-modal-target="view-room-modal-<%= room.id %>" data-modal-toggle="view-room-modal-<%= room.id %>" class="flex-1 px-3 py-2 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 dark:bg-blue-900 dark:text-blue-300 dark:hover:bg-blue-800">
              View
            </button>
            <button data-modal-target="edit-room-modal-<%= room.id %>" data-modal-toggle="edit-room-modal-<%= room.id %>" class="flex-1 px-3 py-2 text-xs font-medium text-gray-600 bg-gray-50 rounded-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
              Edit
            </button>
          </div>
        </div>
      </div>
      <!-- View Modal -->
      <div id="view-room-modal-<%= room.id %>" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full bg-gray-900/50">
        <div class="relative p-4 w-full max-w-2xl h-full md:h-auto">
          <div class="relative p-6 bg-white rounded-lg shadow dark:bg-gray-800">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white"><%= room.name %></h3>
                <p class="text-gray-600 dark:text-gray-400"><%= room.room_type.name %></p>
              </div>
              <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="view-room-modal-<%= room.id %>">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                </svg>
              </button>
            </div>
            <div class="space-y-4">
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Price per night</p>
                  <p class="text-lg font-semibold text-gray-900 dark:text-white">$<%= room.price %></p>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</p>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= room.available? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                    <%= room.available? ? 'Available' : 'Occupied' %>
                  </span>
                </div>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Description</p>
                <p class="text-gray-900 dark:text-white"><%= room.description %></p>
              </div>
              <% if room.facilities.any? %>
                <div>
                  <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">All Facilities</p>
                  <div class="flex flex-wrap gap-2">
                    <% room.facilities.each do |facility| %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= facility&.section_type_badge_color %>">
                        <%= facility.name %> (<%= facility&.section_type&.humanize %>)
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="flex justify-end gap-3 mt-6">
              <%= button_to "Delete", room, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-4 focus:ring-red-300" %>
              <button data-modal-target="edit-room-modal-<%= room.id %>" data-modal-toggle="edit-room-modal-<%= room.id %>" data-modal-hide="view-room-modal-<%= room.id %>" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300">
                Edit Room
              </button>
            </div>
          </div>
        </div>
      </div>
      <!-- Edit Modal -->
      <div id="edit-room-modal-<%= room.id %>" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full bg-gray-900/50">
        <div class="relative p-4 w-full max-w-2xl h-full md:h-auto">
          <div class="relative p-6 bg-white rounded-lg shadow dark:bg-gray-800">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Room</h3>
              <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="edit-room-modal-<%= room.id %>">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                </svg>
              </button>
            </div>
            <%= render 'form', room: room %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <%= render 'shared/pagination', pagy: @pagy %>
</div>
<!-- Add Room Modal -->
<div id="room-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full bg-gray-900/50">
  <div class="relative p-4 w-full max-w-2xl h-full md:h-auto">
    <div class="relative p-6 bg-white rounded-lg shadow dark:bg-gray-800">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Add New Room</h3>
        <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="room-modal">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
      <%= render 'form', room: @room_form %>
    </div>
  </div>
</div>
<div id="room-modal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden bg-gray-900/90 w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-modal md:h-full">
  <div class="relative w-full h-full max-w-2xl md:h-auto">
    <div class="relative dark:bg-gray-800 rounded-lg shadow dark:bg-gray-700">
      <div class="flex items-start justify-between p-4 border-b rounded-t dark:border-gray-600">
        <h3 class="text-2xl font-semibold text-gray-900 dark:text-white">
          Add room
        </h3>
        <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="room-modal">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
      <div class="px-5 pb-5 space-y-6">
        <%= render 'form', room: @room_form %>
      </div>
    </div>
  </div>
  <!-- Pagination -->
  <div class="mt-8">
    <%= render 'shared/pagination', pagy: @pagy %>
  </div>
</div>