<% content_for :title, "New Reservation" %>
<div class="p-4 bg-gray-50 dark:bg-gray-900 min-h-screen">
  <!-- Header -->
  <div class="mb-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 text-sm font-medium md:space-x-2">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-gray-700 hover:text-blue-600 dark:text-gray-300 dark:hover:text-white" do %>
            <svg class="w-5 h-5 mr-2.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
            </svg>
            Home
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 text-gray-400 md:ml-2 dark:text-gray-500" aria-current="page">New Reservations</span>
          </div>
        </li>
      </ol>
    </nav>
    <!-- Title and Actions -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">New Reservation</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Create new Reservation</p>
      </div>
      
    </div>
  </div>
  <%= form_with url: reservations_path, method: :post, local: true, class: "space-y-8" do |form| %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Customer Information -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Customer Information</h2>
        <div class="space-y-4">
          <div>
            <%= form.label "customer[email]", "Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.email_field "customer[email]", value: @customer&.email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", placeholder: "customer@example.com", required: true %>
            <% if @customer&.errors&.[](:email)&.any? %>
              <p class="mt-1 text-sm text-red-600"><%= @customer.errors[:email].first %></p>
            <% end %>
          </div>
          <div>
            <%= form.label "customer[full_name]", "Full Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.text_field "customer[full_name]", value: @customer&.full_name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", placeholder: "John Doe", required: true %>
            <% if @customer&.errors&.[](:full_name)&.any? %>
              <p class="mt-1 text-sm text-red-600"><%= @customer.errors[:full_name].first %></p>
            <% end %>
          </div>
          <div>
            <%= form.label "customer[address]", "Address", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.text_area "customer[address]", value: @customer&.address, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", placeholder: "123 Main Street" %>
          </div>
          <div>
            <%= form.label "customer[city]", "City", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.text_field "customer[city]", value: @customer&.city, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", placeholder: "New York" %>
          </div>
        </div>
      </div>
      <!-- Booking Information -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Booking Details</h2>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label "booking[start_date]", "Check-in Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
              <%= form.date_field "booking[start_date]", 
                  value: @booking&.start_date || params[:start_date], 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", 
                  required: true %>
              <% if @booking&.errors&.[](:start_date)&.any? %>
                <p class="mt-1 text-sm text-red-600"><%= @booking.errors[:start_date].first %></p>
              <% end %>
            </div>
            <div>
              <%= form.label "booking[finish_date]", "Check-out Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
              <%= form.date_field "booking[finish_date]", 
                  value: @booking&.finish_date || params[:end_date], 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", 
                  required: true %>
              <% if @booking&.errors&.[](:finish_date)&.any? %>
                <p class="mt-1 text-sm text-red-600"><%= @booking.errors[:finish_date].first %></p>
              <% end %>
            </div>
          </div>
          <div>
            <%= form.label "booking[payment_method]", "Payment Method", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.select "booking[payment_method]", 
                options_for_select([
                  ['Credit Card', 'credit_card'],
                  ['Cash', 'cash'],
                  ['Bank Transfer', 'bank_transfer'],
                  ['Online Payment', 'online_payment']
                ], @booking&.payment_method), 
                { prompt: 'Select payment method' },
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white", required: true } %>
            <% if @booking&.errors&.[](:payment_method)&.any? %>
              <p class="mt-1 text-sm text-red-600"><%= @booking.errors[:payment_method].first %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- Room Filters -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Filter Rooms</h2>
      <%= form_with url: new_reservation_path, method: :get, local: true, id: "room-filter-form", class: "space-y-4" do |filter_form| %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Room Type Filter -->
          <div>
            <%= filter_form.label :room_type_id, "Room Type", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= filter_form.select :room_type_id, 
                options_from_collection_for_select(@room_types, :id, :name, params[:room_type_id]), 
                { prompt: 'All Room Types' },
                { class: "filter-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" } %>
          </div>
          <!-- Date Range Filter -->
          <div>
            <%= filter_form.label :start_date, "Check-in Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= filter_form.date_field :start_date, 
                value: params[:start_date], 
                class: "filter-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
          </div>
          <div>
            <%= filter_form.label :end_date, "Check-out Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= filter_form.date_field :end_date, 
                value: params[:end_date], 
                class: "filter-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
          </div>
          <!-- Price Range Filter -->
          <div class="flex space-x-2">
            <div class="flex-1">
              <%= filter_form.label :min_price, "Min Price", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
              <%= filter_form.number_field :min_price, 
                  value: params[:min_price], 
                  placeholder: "0", 
                  min: 0,
                  class: "filter-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
            </div>
            <div class="flex-1">
              <%= filter_form.label :max_price, "Max Price", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
              <%= filter_form.number_field :max_price, 
                  value: params[:max_price], 
                  placeholder: "999", 
                  min: 0,
                  class: "filter-input w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
            </div>
          </div>
        </div>
        <!-- Filter Actions -->
        <div class="flex justify-between items-center pt-4 border-t border-gray-200 dark:border-gray-600">
          <div class="text-sm text-gray-500 dark:text-gray-400">
            Showing <%= @rooms.count %> available room<%= 's' if @rooms.count != 1 %>
          </div>
          <div class="flex space-x-3">
            <%= link_to "Clear Filters", new_reservation_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200 focus:ring-4 focus:ring-gray-300 dark:bg-gray-700 dark:text-white dark:border-gray-600 dark:hover:bg-gray-600" %>
            <%= filter_form.submit "Apply Filters", class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          </div>
        </div>
      <% end %>
    </div>
    <script>
      // Auto-submit form when filters change (except for text inputs)
      document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('room-filter-form');
        const selects = form.querySelectorAll('select');
        const dateInputs = form.querySelectorAll('input[type="date"]');

        selects.forEach(select => {
          select.addEventListener('change', function() {
            form.submit();
          });
        });

        dateInputs.forEach(input => {
          input.addEventListener('change', function() {
            form.submit();
          });
        });
      });
    </script>
    <!-- Room Selection -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Select Rooms</h2>
        <% if @rooms.empty? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">
            No rooms match your criteria
          </span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
            <%= @rooms.count %> room<%= 's' if @rooms.count != 1 %> available
          </span>
        <% end %>
      </div>
      <% if @rooms.empty? %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h.01M7 3h.01" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No rooms available</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Try adjusting your filters to see more rooms.</p>
        </div>
      <% else %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @rooms.each do |room| %>
            <div class="border border-gray-200 dark:border-gray-600 rounded-lg p-4 hover:shadow-md transition-shadow <%= 'border-green-300 bg-green-50 dark:bg-green-900/20' if room.available? %>">
              <div class="flex items-center mb-3">
                <%= form.check_box "booking[room_ids][]", { multiple: true, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" }, room.id, nil %>
                <label for="booking_room_ids_<%= room.id %>" class="ml-2 block text-sm font-medium text-gray-900 dark:text-white">
                  <%= room.name %>
                </label>
                <% if room.available? %>
                  <span class="ml-auto inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
                    Available
                  </span>
                <% end %>
              </div>
              <div class="space-y-2 text-sm">
                <p class="text-gray-600 dark:text-gray-400">
                  <span class="font-medium">Type:</span>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300">
                    <%= room.room_type.name %>
                  </span>
                </p>
                <p class="text-gray-600 dark:text-gray-400">
                  <span class="font-medium">Price:</span>
                  <span class="text-lg font-semibold text-green-600 dark:text-green-400">$<%= room.price %></span>/night
                </p>
                <% if room.facilities.room_facilities.any? %>
                  <div>
                    <span class="font-medium text-gray-600 dark:text-gray-400">Facilities:</span>
                    <div class="flex flex-wrap gap-1 mt-1">
                      <% room.facilities.room_facilities.limit(3).each do |facility| %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                          <%= facility.name %>
                        </span>
                      <% end %>
                      <% if room.facilities.room_facilities.count > 3 %>
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400">
                          +<%= room.facilities.room_facilities.count - 3 %> more
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <!-- Submit Button -->
    <div class="flex justify-end space-x-4">
      <%= link_to "Cancel", bookings_path, class: "px-6 py-3 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:ring-4 focus:ring-gray-300 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:focus:ring-gray-600" %>
      <%= form.submit "Create Reservation", class: "px-6 py-3 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
    </div>
  <% end %>
</div>
